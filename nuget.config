<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Public repo: nuget.org only. The Blender plugin consumes the same public
       packages any third-party initiator author would (OutWit.Cloud.SDK,
       OutWit.Controller.Render.Model, OutWit.Common.*, OutWit.Communication.*).
       Keeping a single public source is the conformance check: if anything here
       needed a private feed, the build would fail — which would mean the public
       surface is incomplete. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
