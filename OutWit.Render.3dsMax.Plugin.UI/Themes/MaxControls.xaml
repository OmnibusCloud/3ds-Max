<!--
  OmnibusCloud 3ds Max plugin control styles (design section 5, decision D5: pure XAML, no UI framework).
  Implicit styles for every control the dialogs use, keyed variants for primary/danger buttons and the
  segmented / sidebar radio shapes. Everything is keyed to the Max.Brush.* palette via DynamicResource so
  the light palette appended by MaxThemeResources wins in light mode. Native Windows-dialog idiom:
  32px inputs, 5px radius, group boxes with a floating legend — never stock Aero chrome.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ Focus visual (keyboard navigation must stay visible on hand-rolled templates) ============ -->
    <Style x:Key="Max.FocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="-2" RadiusX="4" RadiusY="4" SnapsToDevicePixels="True"
                               Stroke="{DynamicResource Max.Brush.Accent}" StrokeThickness="1" StrokeDashArray="2 2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Buttons ============ -->
    <Style TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{StaticResource Max.FocusVisual}" />
        <Setter Property="Background" Value="{DynamicResource Max.Brush.Panel}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Max.Brush.ButtonEdge}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.ControlPressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary action: accent fill, navy text, no border (mockup .bbtn.pri) -->
    <Style x:Key="Max.Button.Primary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource Max.Brush.Accent}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.OnAccent}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" CornerRadius="5" Background="{TemplateBinding Background}">
                        <ContentPresenter Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.AccentHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.AccentPressed}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger action: coral text on muted red face (mockup .bbtn.dng — Cancel while a job runs) -->
    <Style x:Key="Max.Button.Danger" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource Max.Brush.DangerFace}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.DangerText}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Max.Brush.DangerEdge}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Chrome" CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ContentPresenter Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Opacity" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ TextBox ============ -->
    <Style TargetType="TextBox">
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Background" Value="{DynamicResource Max.Brush.Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Max.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Max.Brush.Accent}" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Chrome" CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Max.Brush.CheckEdge}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Max.Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ComboBox (non-editable; the dialogs never use IsEditable) ============ -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Chrome" CornerRadius="3" Margin="2,1" Background="Transparent">
                        <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.ItemHover}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.ItemSelected}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FocusVisualStyle" Value="{StaticResource Max.FocusVisual}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="Chrome" Focusable="False" ClickMode="Press"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Face" CornerRadius="5"
                                            Background="{DynamicResource Max.Brush.Input}"
                                            BorderBrush="{DynamicResource Max.Brush.Border}"
                                            BorderThickness="1">
                                        <Path HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,1,11,0"
                                              Data="M 0 0 L 4 4 L 8 0"
                                              Stroke="{DynamicResource Max.Brush.TextMuted}" StrokeThickness="1.6"
                                              StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Face" Property="BorderBrush" Value="{DynamicResource Max.Brush.CheckEdge}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Face" Property="BorderBrush" Value="{DynamicResource Max.Brush.Accent}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <ContentPresenter Margin="11,0,30,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />

                        <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade"
                               StaysOpen="False">
                            <Border Margin="0,3,12,12" MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{DynamicResource Max.Brush.Popup}"
                                    BorderBrush="{DynamicResource Max.Brush.GroupBorder}"
                                    BorderThickness="1" CornerRadius="5" Padding="0,3">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.4" />
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ CheckBox (15px box, accent fill when checked — mockup .cbox) ============ -->
    <Style TargetType="CheckBox">
        <Setter Property="FocusVisualStyle" Value="{StaticResource Max.FocusVisual}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Box" Width="15" Height="15" CornerRadius="3" VerticalAlignment="Center"
                                Background="{DynamicResource Max.Brush.CheckFace}"
                                BorderBrush="{DynamicResource Max.Brush.CheckEdge}" BorderThickness="1">
                            <Path x:Name="Mark" Data="M 1.5 5 L 4.5 8 L 9.5 1.5" Margin="1"
                                  Stroke="{DynamicResource Max.Brush.OnAccent}" StrokeThickness="2" Visibility="Collapsed"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Border>
                        <ContentPresenter Grid.Column="1" Margin="8,0,0,0" RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Max.Brush.TextMuted}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource Max.Brush.Accent}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource Max.Brush.Accent}" />
                            <Setter TargetName="Mark" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ RadioButton (default round; keyed shapes below for segments / sidebar nav) ============ -->
    <Style TargetType="RadioButton">
        <Setter Property="FocusVisualStyle" Value="{StaticResource Max.FocusVisual}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="Ring" Width="15" Height="15" VerticalAlignment="Center"
                                 Fill="{DynamicResource Max.Brush.CheckFace}"
                                 Stroke="{DynamicResource Max.Brush.CheckEdge}" StrokeThickness="1" />
                        <Ellipse x:Name="Dot" Width="7" Height="7" VerticalAlignment="Center" HorizontalAlignment="Center"
                                 Fill="{DynamicResource Max.Brush.Accent}" Visibility="Collapsed" />
                        <ContentPresenter Grid.Column="1" Margin="8,0,0,0" RecognizesAccessKey="True"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Ring" Property="Stroke" Value="{DynamicResource Max.Brush.TextMuted}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Dot" Property="Visibility" Value="Visible" />
                            <Setter TargetName="Ring" Property="Stroke" Value="{DynamicResource Max.Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--
      Segmented control segment (mockup .seg). Set Tag to a CornerRadius per position
      (<CornerRadius>5,0,0,5</CornerRadius> for the first, 0,5,5,0 for the last) and overlap inner
      borders with Margin="-1,0,0,0" on every segment after the first.
    -->
    <Style x:Key="Max.Radio.Segment" TargetType="RadioButton">
        <Setter Property="FocusVisualStyle" Value="{StaticResource Max.FocusVisual}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.TextMuted}" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Chrome"
                            Background="{DynamicResource Max.Brush.SegmentFace}"
                            BorderBrush="{DynamicResource Max.Brush.Border}" BorderThickness="1"
                            CornerRadius="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}">
                        <ContentPresenter Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.ControlHover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.SegmentOn}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Max.Brush.SegmentOnEdge}" />
                            <Setter Property="Foreground" Value="{DynamicResource Max.Brush.SegmentOnText}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter TargetName="Chrome" Property="Panel.ZIndex" Value="1" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Settings sidebar navigation item (design 4.3) -->
    <Style x:Key="Max.Radio.Sidebar" TargetType="RadioButton">
        <Setter Property="FocusVisualStyle" Value="{StaticResource Max.FocusVisual}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.TextMuted}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Chrome" CornerRadius="5" Margin="0,1" Background="Transparent">
                        <ContentPresenter Margin="{TemplateBinding Padding}" RecognizesAccessKey="True"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.ItemHover}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Max.Brush.SidebarActive}" />
                            <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ GroupBox with floating legend (mockup .grp/.lg — Windows group idiom) ============ -->
    <Style TargetType="GroupBox">
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="Padding" Value="13,12,13,13" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.RowSpan="2" Margin="0,7,0,0" CornerRadius="6"
                                BorderBrush="{DynamicResource Max.Brush.GroupBorder}" BorderThickness="1" />
                        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="11,0,0,0" Padding="6,0"
                                Background="{DynamicResource Max.Brush.Window}">
                            <ContentPresenter ContentSource="Header"
                                              TextElement.FontSize="10"
                                              TextElement.Foreground="{DynamicResource Max.Brush.TextMuted}" />
                        </Border>
                        <ContentPresenter Grid.Row="1" Margin="{TemplateBinding Padding}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ ProgressBar (8px rounded track, accent fill; indeterminate pulses) ============ -->
    <Style TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Accent}" />
        <Setter Property="Background" Value="{DynamicResource Max.Brush.TrackFace}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Max.Brush.TrackEdge}" />
        <Setter Property="Height" Value="8" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" />
                        <Border x:Name="PART_Indicator" CornerRadius="4" HorizontalAlignment="Left"
                                Background="{TemplateBinding Foreground}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsIndeterminate" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetName="PART_Indicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         From="0.9" To="0.3" Duration="0:0:0.7" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_Indicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ Slim scrollbars (Settings content, Diagnostics dialog) ============ -->
    <Style x:Key="Max.Scroll.PageButton" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Max.Scroll.Thumb" TargetType="Thumb">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{DynamicResource Max.Brush.ScrollThumb}" CornerRadius="4" Margin="2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource Max.Scroll.PageButton}" Command="ScrollBar.PageUpCommand" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Max.Scroll.Thumb}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource Max.Scroll.PageButton}" Command="ScrollBar.PageDownCommand" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Height" Value="10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource Max.Scroll.PageButton}" Command="ScrollBar.PageLeftCommand" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource Max.Scroll.Thumb}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource Max.Scroll.PageButton}" Command="ScrollBar.PageRightCommand" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============ ToolTip ============ -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource Max.Brush.Popup}" />
        <Setter Property="Foreground" Value="{DynamicResource Max.Brush.Text}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Max.Brush.GroupBorder}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border CornerRadius="5" Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
