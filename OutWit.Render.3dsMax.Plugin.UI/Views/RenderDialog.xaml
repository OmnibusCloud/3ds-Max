<Window x:Class="OutWit.Render.ThreeDsMax.Plugin.UI.Views.RenderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OutWit.Render.ThreeDsMax.Plugin.UI.Converters"
        xmlns:vm="clr-namespace:OutWit.Render.ThreeDsMax.Plugin.UI.ViewModels"
        Title="OmnibusCloud — Render"
        Width="452"
        Height="432"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Max.Brush.Window}"
        TextElement.Foreground="{DynamicResource Max.Brush.Text}"
        FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OutWit.Render.3dsMax.Plugin.UI;component/Themes/MaxPalette.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:EnumToBooleanConverter x:Key="EnumToBool" />
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource Max.Brush.TitleBar}" Padding="14,10">
            <StackPanel>
                <TextBlock Text="Render on OmnibusCloud" FontSize="14" FontWeight="SemiBold" />
                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource Max.Brush.TextMuted}"
                           Text="{Binding SummaryVm.SceneName}" />
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="14,12">

            <!-- Output (2 axes) -->
            <Border Background="{DynamicResource Max.Brush.Panel}" BorderBrush="{DynamicResource Max.Brush.GroupBorder}"
                    BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="Output" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal">
                        <RadioButton GroupName="OutputAxis" Content="Image" Margin="0,0,16,0"
                                     IsChecked="{Binding OutputAxis, Converter={StaticResource EnumToBool}, ConverterParameter=Image}" />
                        <RadioButton GroupName="OutputAxis" Content="Animation"
                                     IsChecked="{Binding OutputAxis, Converter={StaticResource EnumToBool}, ConverterParameter=Animation}" />
                    </StackPanel>

                    <!-- Image sub-axis -->
                    <CheckBox Margin="0,8,0,0" Content="Split frame across machines (tiled)"
                              Visibility="{Binding IsImageOutput, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding SplitFrame}" />

                    <!-- Animation sub-axis -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                Visibility="{Binding IsAnimationOutput, Converter={StaticResource BoolToVis}}">
                        <RadioButton GroupName="AnimResult" Content="Sequence" Margin="0,0,16,0"
                                     IsChecked="{Binding AnimationResult, Converter={StaticResource EnumToBool}, ConverterParameter=Sequence}" />
                        <RadioButton GroupName="AnimResult" Content="Video"
                                     IsChecked="{Binding AnimationResult, Converter={StaticResource EnumToBool}, ConverterParameter=Video}" />
                    </StackPanel>

                    <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource Max.Brush.TextMuted}"
                               Text="{Binding LaunchVm.RenderResolutionText}" />
                </StackPanel>
            </Border>

            <!-- Target -->
            <Border Background="{DynamicResource Max.Brush.Panel}" BorderBrush="{DynamicResource Max.Brush.GroupBorder}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="Target" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <CheckBox Content="Run on the whole network"
                              Visibility="{Binding LaunchVm.CanRunOnAllClientsOption, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding LaunchVm.UseAllClients}" />

                    <ComboBox Margin="0,8,0,0"
                              ItemsSource="{Binding LaunchVm.AvailableGroupNames}"
                              SelectedItem="{Binding LaunchVm.SelectedGroupName}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="IsEnabled" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LaunchVm.UseAllClients}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- V-Ray scanned materials (visible only when the scene uses them) -->
            <Border Background="{DynamicResource Max.Brush.Panel}" BorderBrush="{DynamicResource Max.Brush.GroupBorder}"
                    BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,10,0,0"
                    Visibility="{Binding HasVRayScannedMaterials, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="V-Ray scanned materials" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <CheckBox Content="Bake scanned materials with local V-Ray before upload"
                              IsChecked="{Binding BakeVRayScannedMaterials}" />
                    <TextBlock Margin="22,4,0,0" FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource Max.Brush.TextMuted}"
                               Text="Renders each scanned (.vrscan) material's surface into a texture on this machine before submitting (interactive 3ds Max only) — preserves fabric/suede detail the neutral export cannot carry, at the cost of extra local render time." />
                </StackPanel>
            </Border>

            <!-- Progress (during an active job) -->
            <ProgressBar Margin="0,12,0,0" Height="4" Minimum="0" Maximum="1"
                         Foreground="{DynamicResource Max.Brush.Accent}"
                         Value="{Binding RenderProgress, Mode=OneWay}"
                         Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}" />
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource Max.Brush.Footer}" Padding="14,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CloudVm.UserDisplayName}" FontSize="11" />
                    <TextBlock Text="{Binding StatusLine}" FontSize="11"
                               Foreground="{DynamicResource Max.Brush.TextMuted}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Details…" Padding="10,5" Margin="0,0,8,0" Command="{Binding DetailsCommand}" />
                    <Button Content="Cancel" Padding="10,5" Margin="0,0,8,0" Command="{Binding CancelCommand}"
                            IsEnabled="{Binding CanCancel}"
                            Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}" />

                    <!-- Result actions (shown when a render has completed) -->
                    <Button Content="Open" Padding="10,5" Margin="0,0,8,0" Command="{Binding OpenResultCommand}"
                            Visibility="{Binding ShowResultActions, Converter={StaticResource BoolToVis}}" />
                    <Button Content="Open folder" Padding="10,5" Margin="0,0,8,0" Command="{Binding OpenFolderCommand}"
                            Visibility="{Binding ShowResultActions, Converter={StaticResource BoolToVis}}" />
                    <Button Content="New render" Padding="10,5" Margin="0,0,8,0" Command="{Binding NewRenderCommand}"
                            Visibility="{Binding ShowResultActions, Converter={StaticResource BoolToVis}}" />

                    <Button Content="Render" Padding="14,5" Command="{Binding RenderCommand}"
                            IsEnabled="{Binding CanRender}"
                            Background="{DynamicResource Max.Brush.Accent}" Foreground="{DynamicResource Max.Brush.OnAccent}"
                            FontWeight="SemiBold"
                            Visibility="{Binding ShowRenderButton, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
