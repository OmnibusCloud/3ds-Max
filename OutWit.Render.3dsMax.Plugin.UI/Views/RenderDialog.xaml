<Window x:Class="OutWit.Render.ThreeDsMax.Plugin.UI.Views.RenderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OutWit.Render.ThreeDsMax.Plugin.UI.Converters"
        Title="OmnibusCloud — Render"
        Width="560"
        MinHeight="432"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Max.Brush.Window}"
        TextElement.Foreground="{DynamicResource Max.Brush.Text}"
        FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OmnibusCloud.3dsMax.Plugin.UI;component/Themes/MaxPalette.xaml" />
                <ResourceDictionary Source="/OmnibusCloud.3dsMax.Plugin.UI;component/Themes/MaxControls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:EnumToBooleanConverter x:Key="EnumToBool" />
            <BooleanToVisibilityConverter x:Key="BoolToVis" />

            <!-- Quick-settings row label (mockup .frow .k) -->
            <Style x:Key="RowLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{DynamicResource Max.Brush.TextMuted}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Width" Value="56" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Body: one work-area view at a time (design 4.1.3) — config, active phase, completed, failed -->
        <Grid Grid.Row="0" Margin="16,14,16,12" MinHeight="340">

        <StackPanel Visibility="{Binding ShowConfigView, Converter={StaticResource BoolToVis}}">

            <!-- Scene line: file — resolution · frames (read-only, from the scene) -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <Path Style="{StaticResource Max.InlineIcon}" Data="{StaticResource Max.Icon.Photo}" Margin="0,0,8,0" />
                <TextBlock Text="{Binding SummaryVm.SceneName}" FontWeight="Medium" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" MaxWidth="180" />
                <TextBlock Foreground="{DynamicResource Max.Brush.TextMuted}" VerticalAlignment="Center"
                           FontSize="11.5"><Run Text=" — " /><Run Text="{Binding SummaryVm.RenderResolutionText, Mode=OneWay}" /><Run Text=" · frames " /><Run Text="{Binding SummaryVm.FrameRangeText, Mode=OneWay}" /></TextBlock>
            </StackPanel>

            <!-- Output (2 axes + quick settings — design 4.1.2; every value travels in the launch request) -->
            <GroupBox Header="OUTPUT">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RadioButton Style="{StaticResource Max.Radio.Segment}" GroupName="OutputAxis"
                                     IsChecked="{Binding OutputAxis, Converter={StaticResource EnumToBool}, ConverterParameter=Image}">
                            <RadioButton.Tag><CornerRadius>5,0,0,5</CornerRadius></RadioButton.Tag>
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Photo}" />
                                <TextBlock Text="Image" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Grid.Column="1" Margin="-1,0,0,0" Style="{StaticResource Max.Radio.Segment}"
                                     GroupName="OutputAxis"
                                     IsChecked="{Binding OutputAxis, Converter={StaticResource EnumToBool}, ConverterParameter=Animation}">
                            <RadioButton.Tag><CornerRadius>0,5,5,0</CornerRadius></RadioButton.Tag>
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Film}" />
                                <TextBlock Text="Animation" />
                            </StackPanel>
                        </RadioButton>
                    </Grid>

                    <!-- Image sub-axis -->
                    <CheckBox Margin="0,12,0,0" Content="Split frame across machines (tiled)"
                              Visibility="{Binding IsImageOutput, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding SplitFrame}" />

                    <!-- Tiled grid (mockup: Tiles 4 × 4 · Overlap 8 px) -->
                    <DockPanel Margin="0,11,0,0" Visibility="{Binding ShowTiles, Converter={StaticResource BoolToVis}}">
                        <TextBlock Style="{StaticResource RowLabel}" Text="Tiles" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="60" Text="{Binding TilesX}" HorizontalContentAlignment="Center" />
                            <TextBlock Text="×" Margin="7,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Max.Brush.TextMuted}" />
                            <TextBox Width="60" Text="{Binding TilesY}" HorizontalContentAlignment="Center" />
                            <TextBlock Text="Overlap" Margin="16,0,7,0" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{DynamicResource Max.Brush.TextMuted}" />
                            <TextBox Width="60" Text="{Binding TileOverlap}" HorizontalContentAlignment="Center" />
                            <TextBlock Text="px" Margin="7,0,0,0" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{DynamicResource Max.Brush.TextMuted}" />
                        </StackPanel>
                    </DockPanel>

                    <!-- Animation sub-axis -->
                    <Grid Margin="0,12,0,0"
                          Visibility="{Binding IsAnimationOutput, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <RadioButton Style="{StaticResource Max.Radio.Segment}" GroupName="AnimResult" Content="Image sequence"
                                     IsChecked="{Binding AnimationResult, Converter={StaticResource EnumToBool}, ConverterParameter=Sequence}">
                            <RadioButton.Tag><CornerRadius>5,0,0,5</CornerRadius></RadioButton.Tag>
                        </RadioButton>
                        <RadioButton Grid.Column="1" Margin="-1,0,0,0" Style="{StaticResource Max.Radio.Segment}"
                                     GroupName="AnimResult" Content="Video"
                                     IsChecked="{Binding AnimationResult, Converter={StaticResource EnumToBool}, ConverterParameter=Video}">
                            <RadioButton.Tag><CornerRadius>0,5,5,0</CornerRadius></RadioButton.Tag>
                        </RadioButton>
                    </Grid>

                    <!-- Format (stills / sequences) — defaults from Settings ▸ Output, editable per launch -->
                    <DockPanel Margin="0,11,0,0" Visibility="{Binding ShowImageFormat, Converter={StaticResource BoolToVis}}">
                        <TextBlock Style="{StaticResource RowLabel}" Text="Format" />
                        <ComboBox ItemsSource="{Binding AvailableImageFormats}" SelectedItem="{Binding SelectedImageFormat}" />
                    </DockPanel>

                    <!-- Codec (video) -->
                    <DockPanel Margin="0,11,0,0" Visibility="{Binding ShowVideoOptions, Converter={StaticResource BoolToVis}}">
                        <TextBlock Style="{StaticResource RowLabel}" Text="Codec" />
                        <ComboBox ItemsSource="{Binding AvailableVideoPresets}" SelectedItem="{Binding SelectedVideoPreset}" />
                    </DockPanel>

                    <!-- Range (animation) — seeded from the scene, editable -->
                    <DockPanel Margin="0,11,0,0" Visibility="{Binding IsAnimationOutput, Converter={StaticResource BoolToVis}}">
                        <TextBlock Style="{StaticResource RowLabel}" Text="Range" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="70" Text="{Binding LaunchVm.FrameStart}" HorizontalContentAlignment="Center" />
                            <TextBlock Text="–" Margin="7,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Max.Brush.TextMuted}" />
                            <TextBox Width="70" Text="{Binding LaunchVm.FrameEnd}" HorizontalContentAlignment="Center" />
                            <TextBlock Text="from scene" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="10.5"
                                       Foreground="{DynamicResource Max.Brush.TextMuted}" />
                        </StackPanel>
                    </DockPanel>

                    <!-- Resolution — from the scene, editable; lock chains the aspect, reset restores the scene value -->
                    <DockPanel Margin="0,11,0,0">
                        <TextBlock Style="{StaticResource RowLabel}" Text="Size" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox Width="70" Text="{Binding LaunchVm.ResolutionX}" HorizontalContentAlignment="Center" />
                            <TextBlock Text="×" Margin="7,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Max.Brush.TextMuted}" />
                            <TextBox Width="70" Text="{Binding LaunchVm.ResolutionY}" HorizontalContentAlignment="Center" />
                            <ToggleButton Style="{StaticResource Max.Button.IconToggle}" Margin="10,0,0,0"
                                          IsChecked="{Binding LockAspectRatio}"
                                          ToolTip="Lock aspect ratio — editing one side recomputes the other">
                                <Path Style="{StaticResource Max.ButtonIcon}" Margin="0"
                                      Data="{StaticResource Max.Icon.Link}" />
                            </ToggleButton>
                            <Button MinHeight="30" Width="30" Padding="0" Margin="6,0,0,0"
                                    Command="{Binding ResetResolutionCommand}"
                                    ToolTip="Reset to the scene resolution">
                                <Path Style="{StaticResource Max.ButtonIcon}" Margin="0"
                                      Data="{StaticResource Max.Icon.Refresh}" />
                            </Button>
                            <TextBlock Text="px" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="10.5"
                                       Foreground="{DynamicResource Max.Brush.TextMuted}" />
                        </StackPanel>
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <!-- Target -->
            <GroupBox Header="TARGET" Margin="0,14,0,0">
                <StackPanel>
                    <CheckBox Content="Run on the whole network" Margin="0,0,0,10"
                              Visibility="{Binding LaunchVm.CanRunOnAllClientsOption, Converter={StaticResource BoolToVis}}"
                              IsChecked="{Binding LaunchVm.UseAllClients}" />

                    <ComboBox ItemsSource="{Binding LaunchVm.AvailableTargets}"
                              SelectedItem="{Binding LaunchVm.SelectedTarget}">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                <Setter Property="IsEnabled" Value="True" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LaunchVm.UseAllClients}" Value="True">
                                        <Setter Property="IsEnabled" Value="False" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                        <ComboBox.ItemTemplate>
                            <!-- Colored kind dot + name + a quiet kind word: projects and groups share one
                                 flat list, and color alone would fail color-blind users. -->
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="{Binding KindBrush}"
                                             VerticalAlignment="Center" Margin="0,0,7,0" />
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding KindLabel}" FontStyle="Italic" Opacity="0.55"
                                               VerticalAlignment="Center" Margin="8,0,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </GroupBox>

            <!-- V-Ray scanned materials (visible only when the scene uses them) -->
            <GroupBox Header="V-RAY SCANNED MATERIALS" Margin="0,14,0,0"
                      Visibility="{Binding HasVRayScannedMaterials, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <CheckBox Content="Bake scanned materials with local V-Ray before upload"
                              IsChecked="{Binding BakeVRayScannedMaterials}" />
                    <TextBlock Margin="23,6,0,0" FontSize="11" TextWrapping="Wrap" LineHeight="16"
                               Foreground="{DynamicResource Max.Brush.TextMuted}"
                               Text="Renders each scanned (.vrscan) material's surface into a texture on this machine before submitting (interactive 3ds Max only) — preserves fabric/suede detail the neutral export cannot carry, at the cost of extra local render time." />
                </StackPanel>
            </GroupBox>

        </StackPanel>

        <!-- Active phase: centered icon + title/counter + bar + sub-line (mockup 4.1.3 cards) -->
        <StackPanel VerticalAlignment="Center" Margin="28,0"
                    Visibility="{Binding ShowActiveView, Converter={StaticResource BoolToVis}}">
            <Border Width="44" Height="44" CornerRadius="22" Margin="0,0,0,14" HorizontalAlignment="Left"
                    Background="{DynamicResource Max.Brush.ItemSelected}">
                <Grid>
                    <Path Style="{StaticResource Max.InlineIcon}" Margin="0" HorizontalAlignment="Center"
                          Stroke="{DynamicResource Max.Brush.SeverityOk}" Data="{StaticResource Max.Icon.Up}"
                          Visibility="{Binding IsUploadPhase, Converter={StaticResource BoolToVis}}" />
                    <Path Style="{StaticResource Max.InlineIcon}" Margin="0" HorizontalAlignment="Center"
                          Stroke="{DynamicResource Max.Brush.SeverityOk}" Data="{StaticResource Max.Icon.Film}"
                          Visibility="{Binding IsRenderPhase, Converter={StaticResource BoolToVis}}" />
                    <Path Style="{StaticResource Max.InlineIcon}" Margin="0" HorizontalAlignment="Center"
                          Stroke="{DynamicResource Max.Brush.SeverityOk}" Data="{StaticResource Max.Icon.Spinner}"
                          Visibility="{Binding IsFinishPhase, Converter={StaticResource BoolToVis}}" />
                    <Path Style="{StaticResource Max.InlineIcon}" Margin="0" HorizontalAlignment="Center"
                          Stroke="{DynamicResource Max.Brush.SeverityWarning}" Data="{StaticResource Max.Icon.X}"
                          Visibility="{Binding IsCancelPhase, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Border>

            <DockPanel Margin="0,0,0,9">
                <TextBlock DockPanel.Dock="Right" Text="{Binding PhaseCounter}" FontSize="12.5"
                           VerticalAlignment="Bottom" Foreground="{DynamicResource Max.Brush.TextMuted}" />
                <TextBlock Text="{Binding PhaseTitle}" FontSize="14" FontWeight="SemiBold" />
            </DockPanel>

            <ProgressBar Minimum="0" Maximum="1" Value="{Binding RenderProgress, Mode=OneWay}"
                         IsIndeterminate="{Binding IsPhaseIndeterminate}" />

            <TextBlock Text="{Binding PhaseSubline}" FontSize="11.5" Margin="0,9,0,0"
                       Foreground="{DynamicResource Max.Brush.TextMuted}" />
        </StackPanel>

        <!-- Completed: check head + result row with thumbnail (mockup Completed card) -->
        <StackPanel VerticalAlignment="Center" Margin="28,0"
                    Visibility="{Binding ShowResultActions, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border Width="30" Height="30" CornerRadius="15" Background="{DynamicResource Max.Brush.ItemSelected}">
                    <Path Style="{StaticResource Max.InlineIcon}" Margin="0" HorizontalAlignment="Center"
                          Stroke="{DynamicResource Max.Brush.SeverityOk}" Data="{StaticResource Max.Icon.Check}" />
                </Border>
                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Render complete" FontSize="13.5" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CompletedMeta}" FontSize="11"
                               Foreground="{DynamicResource Max.Brush.TextMuted}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Border Width="74" Height="55" CornerRadius="6" Background="{DynamicResource Max.Brush.Input}"
                        BorderBrush="{DynamicResource Max.Brush.Border}" BorderThickness="1">
                    <Image Source="{Binding ResultThumbnail}" Stretch="UniformToFill" />
                </Border>
                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ResultFileName}" FontSize="13" FontWeight="SemiBold"
                               MaxWidth="300" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding LaunchVm.RenderResolutionText}" FontSize="11" Margin="0,3,0,0"
                               Foreground="{DynamicResource Max.Brush.TextMuted}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Failed: alert + message + job reference (mockup Failed card) -->
        <StackPanel VerticalAlignment="Center" Margin="28,0"
                    Visibility="{Binding ShowFailedActions, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <Border Width="34" Height="34" CornerRadius="17" VerticalAlignment="Top"
                        Background="{DynamicResource Max.Brush.DangerFace}">
                    <Path Style="{StaticResource Max.InlineIcon}" Margin="0" HorizontalAlignment="Center"
                          Stroke="{DynamicResource Max.Brush.DangerText}" Data="{StaticResource Max.Icon.Alert}" />
                </Border>
                <StackPanel Margin="12,0,0,0" MaxWidth="340">
                    <TextBlock Text="Render failed" FontSize="13.5" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding FailedMessage}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"
                               Foreground="{DynamicResource Max.Brush.TextMuted}" />
                    <Border Margin="0,10,0,0" CornerRadius="4" Padding="8,5" HorizontalAlignment="Left"
                            Background="{DynamicResource Max.Brush.Input}"
                            BorderBrush="{DynamicResource Max.Brush.Border}" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FailedDetail}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding FailedDetail}" FontSize="10.5" FontFamily="Consolas"
                                   Foreground="{DynamicResource Max.Brush.TextMuted}" />
                    </Border>
                </StackPanel>
            </StackPanel>
        </StackPanel>
        </Grid>

        <!-- Footer: account/status on the left, one action set at a time on the right (mockup 4.1.3) -->
        <Border Grid.Row="1" Background="{DynamicResource Max.Brush.Footer}" Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Configuring / blocked / failed: Details + Render -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding ShowConfigActions, Converter={StaticResource BoolToVis}}">
                        <Button Margin="0,0,8,0" Command="{Binding DetailsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Sliders}" />
                                <TextBlock Text="Details…" />
                            </StackPanel>
                        </Button>
                        <Button MinWidth="96" Style="{StaticResource Max.Button.Primary}"
                                Command="{Binding RenderCommand}" IsEnabled="{Binding CanRender}">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Bolt}" />
                                <TextBlock Text="Render" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Active job: Cancel only (close ≠ cancel — the job keeps running) -->
                    <Button MinWidth="96" Style="{StaticResource Max.Button.Danger}"
                            Command="{Binding CancelCommand}" IsEnabled="{Binding CanCancel}"
                            Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.X}" />
                            <TextBlock Text="Cancel" />
                        </StackPanel>
                    </Button>

                    <!-- Completed: result actions -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding ShowResultActions, Converter={StaticResource BoolToVis}}">
                        <Button Margin="0,0,8,0" Command="{Binding OpenResultCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Photo}" />
                                <TextBlock Text="Open" />
                            </StackPanel>
                        </Button>
                        <Button Margin="0,0,8,0" Command="{Binding OpenFolderCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Folder}" />
                                <TextBlock Text="Open folder" />
                            </StackPanel>
                        </Button>
                        <Button MinWidth="96" Style="{StaticResource Max.Button.Primary}" Command="{Binding NewRenderCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Bolt}" />
                                <TextBlock Text="New render" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Failed: Copy log + Retry (mockup Failed card) -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding ShowFailedActions, Converter={StaticResource BoolToVis}}">
                        <Button Margin="0,0,8,0" Command="{Binding CopyLogCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Copy}" />
                                <TextBlock Text="Copy log" />
                            </StackPanel>
                        </Button>
                        <Button MinWidth="96" Style="{StaticResource Max.Button.Primary}"
                                Command="{Binding RenderCommand}" IsEnabled="{Binding CanRender}">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Refresh}" />
                                <TextBlock Text="Retry" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{DynamicResource Max.Brush.TextMuted}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CloudVm.IsSignedIn}" Value="True">
                                            <Setter Property="Fill" Value="{DynamicResource Max.Brush.Accent}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding CloudVm.UserDisplayName}" FontSize="11" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Text="{Binding FooterLine}" FontSize="11" Margin="12,2,0,0" TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Max.Brush.TextMuted}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
