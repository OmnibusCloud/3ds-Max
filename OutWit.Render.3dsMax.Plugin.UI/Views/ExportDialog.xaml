<Window x:Class="OutWit.Render.ThreeDsMax.Plugin.UI.Views.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:OutWit.Render.ThreeDsMax.Plugin.UI.Converters"
        Title="OmnibusCloud — Export"
        Width="508"
        MinHeight="320"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Max.Brush.Window}"
        TextElement.Foreground="{DynamicResource Max.Brush.Text}"
        FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OutWit.Render.3dsMax.Plugin.UI;component/Themes/MaxPalette.xaml" />
                <ResourceDictionary Source="/OutWit.Render.3dsMax.Plugin.UI;component/Themes/MaxControls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:EnumToBooleanConverter x:Key="EnumToBool" />
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Body (no in-window header — scene line per mockup 4.2) -->
        <Grid Grid.Row="0" Margin="16,14,16,12">

            <!-- Ready -->
            <StackPanel Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <Path Style="{StaticResource Max.InlineIcon}" Data="{StaticResource Max.Icon.Photo}" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding SummaryVm.SceneName}" FontWeight="Medium" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" MaxWidth="200" />
                    <TextBlock Foreground="{DynamicResource Max.Brush.TextMuted}" VerticalAlignment="Center"
                               FontSize="11.5"><Run Text=" — " /><Run Text="{Binding SummaryVm.RenderResolutionText, Mode=OneWay}" /></TextBlock>
                </StackPanel>

                <GroupBox Header="TARGET">
                    <StackPanel>
                        <RadioButton GroupName="ExportTarget" Content="Blender scene (.blend) — built on the server"
                                     IsChecked="{Binding Target, Converter={StaticResource EnumToBool}, ConverterParameter=Blend}" />
                        <RadioButton GroupName="ExportTarget" Margin="0,6,0,0" Content="DCC JSON (.json) — local neutral export"
                                     IsChecked="{Binding Target, Converter={StaticResource EnumToBool}, ConverterParameter=DccJson}" />

                        <!-- V-Ray scanned materials (server .blend target only, and only when the scene uses them) -->
                        <StackPanel Visibility="{Binding IsBlend, Converter={StaticResource BoolToVis}}">
                            <StackPanel Visibility="{Binding HasVRayScannedMaterials, Converter={StaticResource BoolToVis}}">
                                <CheckBox Margin="0,10,0,0" Content="Bake scanned materials with local V-Ray before upload"
                                          IsChecked="{Binding BakeVRayScannedMaterials}" />
                                <TextBlock Margin="23,5,0,0" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource Max.Brush.TextMuted}"
                                           Text="Renders each scanned (.vrscan) material's surface into a texture on this machine before submitting (interactive 3ds Max only) — the baked texture is packed into the returned .blend." />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="SAVE TO" Margin="0,14,0,0">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Margin="8,0,0,0" Command="{Binding BrowseCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Folder}" />
                                <TextBlock Text="Browse…" />
                            </StackPanel>
                        </Button>
                        <TextBox Text="{Binding OutputFolder}" />
                    </DockPanel>
                </GroupBox>
            </StackPanel>

            <!-- Exporting -->
            <StackPanel VerticalAlignment="Center" Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding StatusLine}" HorizontalAlignment="Center" />
                <ProgressBar Margin="0,12,0,0" IsIndeterminate="True" />
            </StackPanel>

            <!-- Completed -->
            <StackPanel VerticalAlignment="Center" Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Export complete" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Max.Brush.SeverityOk}" />
                <TextBlock Text="{Binding ResultFileName}" HorizontalAlignment="Center" Margin="0,6,0,0" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
                    <Button Content="Open folder" Margin="0,0,8,0" Command="{Binding OpenFolderCommand}" />
                    <Button Content="New export" Style="{StaticResource Max.Button.Primary}" Command="{Binding NewExportCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- Failed -->
            <StackPanel VerticalAlignment="Center" Visibility="{Binding IsFailed, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Export failed" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"
                           Foreground="{DynamicResource Max.Brush.SeverityError}" />
                <TextBlock Text="{Binding ErrorMessage}" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                <Button Content="New export" Style="{StaticResource Max.Button.Primary}" HorizontalAlignment="Center"
                        Margin="0,14,0,0" Command="{Binding NewExportCommand}" />
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="1" Background="{DynamicResource Max.Brush.Footer}" Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Cancel" Margin="0,0,8,0" Command="{Binding CancelCommand}" />
                    <Button MinWidth="96" Style="{StaticResource Max.Button.Primary}"
                            Command="{Binding ExportCommand}" IsEnabled="{Binding CanExport}"
                            Visibility="{Binding IsReady, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Max.ButtonIcon}" Data="{StaticResource Max.Icon.Up}" />
                            <TextBlock Text="Export" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Ellipse Width="6" Height="6" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource Max.Brush.TextMuted}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CloudVm.IsSignedIn}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource Max.Brush.Accent}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="11" TextTrimming="CharacterEllipsis" Text="{Binding CloudVm.UserDisplayName}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
