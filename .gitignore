# Ignore Visual Studio temporary files, build results, and
# files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

#Nuget
*.nupkg
*.snupkg

# Live/batch test render outputs (generated per run — never commit)
@Publish/

# Internal working documents (design mockups, ship plans, experiments, agent notes) —
# the public repo carries only the READMEs and docs/
@Design/
CLAUDE.md
WitEngine-logo.png

# Local secrets (test API keys, .env) — never commit
.env
*.env

# Mono Auto Generated Files
mono_crash.*

#NuGet Packages
packages/

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2019/2022
.vscode/
.vs/
.vscode/settings.json

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# C# Project files
project.lock.json
project.fragment.lock.json
artifacts/

# Local build artifacts: staged controller modules, packed zips,
# pack-render-prereqs output, and the @Output/GoldenCandidates/
# folder where every Render.Tests run stages its actual render output +
# side-by-side diff for visual inspection. Not part of source.
@Controllers/
@Zips/
@Output/
dist/

# Internal working docs/plans live locally only — this is a public repo.
@Archive/

# Local-only test fixtures: large .max demo scenes (Autodesk samples —
# size + license forbid committing them). Tests `Assert.Ignore` when
# these are missing — CI stays green, but a local dev with @Data
# populated can run the full 3dsmaxbatch smoke suite. See @Data/README.md.
@Prerequisites/
# Ignore @Data contents but re-include the README (scene provenance) and the
# small, committed canonical scenes. (Must be @Data/* not @Data/ so children
# can be re-included.)
@Data/*
!@Data/README.md
!@Data/canonical/

# Autodesk managed SDK assembly: dropped locally into Libs/ from a 3ds Max
# install (or resolved via ADSK_3DSMAX_x64_* env var); never committed.
OutWit.Render.3dsMax.Plugin/Libs/Autodesk.Max.dll

# Staged plugin payload assembled next to test output for 3dsmaxbatch runs
3dsmax-plugin/

# Per-project test output (NUnit/MSTest trx files, coverage reports)
TestResults/

# Auto-generated files by Visual Studio
*.dbmdl
*.pdb
*.cache
*.ilk
*.log
*.userprefs
*.tlog
*.vspscc
*.vspx

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Entity Framework Migrations
Migrations/

# Rider specific folders
.idea/
.idea_modules/

# JetBrains Rider
.idea/
.idea_modules/

